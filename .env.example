# CORTEX v2 — API Keys
# ====================
# Copy this file to .env and fill in your keys.
# .env is in .gitignore — it will NEVER be committed to GitHub.
#
# You only need the keys for providers you want to use.
# The experiment runner auto-detects which keys are set.

# ── Google Gemini ─────────────────────────────────────────────
# Get key: https://aistudio.google.com/app/apikey
# Cheapest option: gemini-2.0-flash (~$0.05 for 18 tasks)
GEMINI_API_KEY=your_gemini_key_here

# ── Grok (xAI) ────────────────────────────────────────────────
# Get key: https://console.x.ai
# Model: grok-3-mini (cheap) or grok-3 (powerful)
GROK_API_KEY=your_grok_key_here

# ── OpenRouter ────────────────────────────────────────────────
# Get key: https://openrouter.ai/keys
# Access to 100+ models. Use free/cheap ones for experiments.
# Default model: meta-llama/llama-3.1-8b-instruct (very cheap)
OPENROUTER_API_KEY=your_openrouter_key_here

# ── OpenAI (optional) ─────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ── Experiment settings (optional overrides) ──────────────────
# CORTEX_REPOS_DIR=/path/to/your/cloned/repos
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
